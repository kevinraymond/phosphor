        { "type": "smooth", "factor": 0.985 },
        { "type": "scale", "factor": 9.0 },
        { "type": "clamp", "lo": 0.15, "hi": 1.0 }
      ]
    },
    {
      "id": "b_005",
      "name": "Brilliance drives the ribs",
      "enabled": true,
      "scope": "Preset",
      "source": "audio.band.6",
      "target": "param.0.Tunnel.rib_density",
      "transforms": [
        { "type": "smooth", "factor": 0.7 },
        { "type": "remap", "in_lo": 0.0, "in_hi": 0.7, "out_lo": 0.2, "out_hi": 1.0 }
      ]
    }
  ]
}
