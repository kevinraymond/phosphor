{
  "version": 1,
  "bindings": [
    {
      "id": "b_001",
      "name": "Sub-bass opens the tunnel",
      "enabled": true,
      "scope": "Preset",
      "source": "audio.band.0",
      "target": "layer.0.opacity",
      "transforms": [
        { "type": "smooth", "factor": 0.55 },
        { "type": "remap", "in_lo": 0.0, "in_hi": 0.8, "out_lo": 0.12, "out_hi": 1.0 }
      ]
    },
    {
      "id": "b_002",
      "name": "Percussive energy curls the cascade",
      "enabled": true,
      "scope": "Preset",
      "source": "audio.percussive_energy",
      "target": "param.1.Cascade.curl_strength",
      "transforms": [
        { "type": "curve", "curve_type": "ease_out" },
        { "type": "remap", "in_lo": 0.0, "in_hi": 1.0, "out_lo": 0.1, "out_hi": 0.95 }
      ]
    },
    {
      "id": "b_003",
      "name": "Harmonic ratio twists the tunnel",
      "enabled": true,
      "scope": "Preset",
      "source": "audio.harmonic_ratio",
      "target": "param.0.Tunnel.twist_amount",
      "transforms": [
        { "type": "smooth", "factor": 0.88 },
        { "type": "remap", "in_lo": 0.2, "in_hi": 0.9, "out_lo": 0.05, "out_hi": 0.95 }
      ]
    },
    {
      "id": "b_004",
      "name": "Drop flare",
      "enabled": true,
      "scope": "Preset",
      "source": "audio.drop",
      "target": "postfx.bloom_intensity",
