{
    "name": "Lattice Pulse",
    "effect_type": "particle",
    "author": "Fosfora",
    "description": "3D cellular automata — Von Neumann oscillating structures (S2-3/B3/2/VN). Bass drives the evolution; the grid freezes in silence.",
    "shader": "",
    "inputs": [],
    "passes": [
        {
            "name": "bg",
            "shader": "lattice_bg.wgsl",
            "feedback": false
        }
    ],
    "particles": {
        "render_mode": "billboard",
        "max_count": 1,
        "emitter": {
            "shape": "point",
            "radius": 0.0,
            "position": [
                0.0,
                0.0
            ]
        },
        "lattice": {
            "grid_res": 128,
            "preset": "Pulse",
            "gen_per_sec": 10.0,
            "bass_floor": 0.35,
            "smooth_rate": 10.0,
            "max_age": 0,
            "boundary": 0,
            "domain_mode": 1,
            "domain_radius": 0.88,
            "dilation_max": 0,
            "init_mode": 4,
            "init_density": 0.55,
            "seed_size": 8,
            "look": {
                "palette_hue": 0.45,
                "absorption": 1.2,
                "emission_gain": 1.7,
                "detail_strength": 0.4,
                "detail_scale": 3.0,
                "cam_distance": 3.2,
                "cam_orbit_speed": 0.2,
                "age_influence": 0.15
            }
        }
    },
    "audio_mappings": [
        {
            "feature": "bass",
            "target": "generation rate — CA generations/second above the silence floor"
        },
        {
            "feature": "mid",
            "target": "birth-mask dilation — denser, more active structures (capped per preset)"
        },
        {
            "feature": "brilliance",
            "target": "survival-mask dilation — longer-lived structures (capped per preset)"
        },
        {
            "feature": "onset",
            "target": "seed-cluster injection on the beat"
        },
        {
            "feature": "flux",
            "target": "random cell perturbation — breaks stasis"
        },
        {
            "feature": "beat_phase",
            "target": "density pulse (in the ray marcher)"
        }
    ]
}
