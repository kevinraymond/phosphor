{
    "name": "Symbiosis",
    "author": "Phosphor",
    "description": "Particle life — multi-species emergent ecosystems, crystals, and predator-prey dynamics from an asymmetric force matrix",
    "shader": "",
    "inputs": [
        {
            "type": "Float",
            "name": "num_species",
            "default": 0.33,
            "min": 0.0,
            "max": 1.0
        },
        {
            "type": "Float",
            "name": "force_scale",
            "default": 0.35,
            "min": 0.0,
            "max": 1.0
        },
        {
            "type": "Float",
            "name": "friction",
            "default": 0.30,
            "min": 0.0,
            "max": 1.0
        },
        {
            "type": "Float",
            "name": "max_radius",
            "default": 0.45,
            "min": 0.0,
            "max": 1.0
        },
        {
            "type": "Float",
            "name": "min_radius",
            "default": 0.32,
            "min": 0.0,
            "max": 1.0
        },
        {
            "type": "Float",
            "name": "color_mode",
            "default": 0.0,
            "min": 0.0,
            "max": 1.0
        },
        {
            "type": "Float",
            "name": "preset",
            "default": 0.75,
            "min": 0.0,
            "max": 1.0
        },
        {
            "type": "Float",
            "name": "audio_drive",
            "default": 1.0,
            "min": 0.0,
            "max": 1.0
        }
    ],
    "passes": [
        {
            "name": "background",
            "shader": "symbiosis_bg.wgsl",
            "feedback": false
        }
    ],
    "particles": {
        "render_mode": "compute",
        "max_count": 200000,
        "max_scaled_count": 1000000,
        "compute_shader": "symbiosis_sim.wgsl",
        "emitter": {
            "shape": "disc",
            "radius": 0.8,
            "position": [0.0, 0.0]
        },
        "lifetime": 999.0,
        "initial_speed": 0.0,
        "initial_size": 0.001,
        "size_end": 0.004,
        "gravity": [0.0, 0.0],
        "drag": 1.0,
        "turbulence": 0.0,
        "attraction_strength": 0.0,
        "emit_rate": 200000.0,
        "burst_on_beat": 0,
        "interaction": true,
        "grid_max": 20,
        "blend": "additive",
        "symbiosis": true
    },
    "postprocess": {
        "enabled": true,
        "bloom_threshold": 0.4,
        "bloom_intensity": 0.35,
        "vignette": 0.25
    },
    "audio_mappings": [
        { "feature": "bass", "target": "force_scale boost (stronger inter-species forces)" },
        { "feature": "mid", "target": "friction modulation (viscosity)" },
        { "feature": "presence + brilliance", "target": "max_radius expansion (wider interaction)" },
        { "feature": "onset", "target": "force matrix entry shuffle (emergent disruption)" },
        { "feature": "flux", "target": "continuous matrix perturbation" },
        { "feature": "mfcc[4..6]", "target": "per-species force modulation (timbre shifts ecology)" },
        { "feature": "dominant_chroma", "target": "species color rotation (pitch class → hue offset)" },
        { "feature": "flux", "target": "interaction radius expansion (spectral change → wider reach)" },
        { "feature": "zcr", "target": "Brownian noise (noisy signal → jittery particles)" }
    ]
}
