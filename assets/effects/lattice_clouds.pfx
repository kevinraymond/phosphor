{
    "name": "Lattice Clouds",
    "effect_type": "particle",
    "author": "Fosfora",
    "description": "3D cellular automata — expanding cumulus-like structures (S13-26/B13-14,17-19/2/M). Bass drives the evolution; the grid freezes in silence.",
    "shader": "",
    "inputs": [],
    "passes": [
        {
            "name": "bg",
            "shader": "lattice_bg.wgsl",
            "feedback": false
        }
    ],
    "particles": {
        "render_mode": "billboard",
        "max_count": 1,
        "emitter": {
            "shape": "point",
            "radius": 0.0,
            "position": [
                0.0,
                0.0
            ]
        },
        "lattice": {
            "grid_res": 128,
            "preset": "Clouds",
            "gen_per_sec": 8.0,
            "bass_floor": 0.35,
            "smooth_rate": 8.0,
            "boundary": 0,
            "domain_mode": 0,
            "domain_radius": 0.95,
            "dilation_max": 0,
            "init_mode": 0,
            "init_density": 0.5,
            "seed_size": 6,
            "look": {
                "palette_hue": 0.6,
                "absorption": 1.8,
                "emission_gain": 1.4,
                "detail_strength": 0.65,
                "detail_scale": 5.0,
                "cam_distance": 3.4,
                "cam_orbit_speed": 0.12,
                "age_influence": 0.1
            }
        }
    },
    "audio_mappings": [
        {
            "feature": "bass",
            "target": "generation rate — CA generations/second above the silence floor"
        },
        {
            "feature": "mid",
            "target": "birth-mask dilation — denser, more active structures (capped per preset)"
        },
        {
            "feature": "brilliance",
            "target": "survival-mask dilation — longer-lived structures (capped per preset)"
        },
        {
            "feature": "onset",
            "target": "seed-cluster injection on the beat"
        },
        {
            "feature": "flux",
            "target": "random cell perturbation — breaks stasis"
        },
        {
            "feature": "beat_phase",
            "target": "density pulse (in the ray marcher)"
        }
    ]
}
