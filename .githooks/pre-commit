#!/usr/bin/env bash
# Pre-commit hook: check formatting and lints before committing.

set -e

# Check cargo fmt
if ! cargo fmt --all -- --check 2>/dev/null; then
    echo "ERROR: cargo fmt check failed. Run 'cargo fmt --all' to fix."
    exit 1
fi

# Check clippy (host target, default features — fast). Use --all-targets so tests,
# benches and examples are linted too, matching CI's base clippy job (a test-only lint
# must not slip through to CI). Windows/macOS cfg-gated code and non-default features
# are linted per-target in CI's build matrix, not here — see CONTRIBUTING.md.
if ! cargo clippy --all-targets -- -D warnings; then
    echo "ERROR: cargo clippy found warnings. Fix them before committing."
    exit 1
fi
