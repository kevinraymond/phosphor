#!/usr/bin/env bash
# Pre-commit hook: check formatting and lints before committing.

set -e

# Guard the CHANGELOG headers release.yml awk-matches to build the release body. CI gates
# the tag on this too, but catching it here means it never reaches a release commit.
if ! scripts/check_changelog.py; then
    echo "ERROR: CHANGELOG check failed. See scripts/check_changelog.py."
    exit 1
fi

# Guard the docs the release also gates on: every shipped effect present in the gallery,
# the effect count in sync, all relative links/anchors resolving. tag.yml checks this too,
# but catching it here stops an effect (Chromatica did, before v1.17.0) reaching a release
# commit without its docs — the release tag can't retrigger on a docs-only fix.
if ! scripts/check_docs.py; then
    echo "ERROR: docs check failed. See scripts/check_docs.py."
    exit 1
fi

# Check cargo fmt
if ! cargo fmt --all -- --check 2>/dev/null; then
    echo "ERROR: cargo fmt check failed. Run 'cargo fmt --all' to fix."
    exit 1
fi

# Check clippy (host target, default features — fast). Use --all-targets so tests,
# benches and examples are linted too, matching CI's base clippy job (a test-only lint
# must not slip through to CI). Windows/macOS cfg-gated code and non-default features
# are linted per-target in CI's build matrix, not here — see CONTRIBUTING.md.
if ! cargo clippy --all-targets -- -D warnings; then
    echo "ERROR: cargo clippy found warnings. Fix them before committing."
    exit 1
fi
